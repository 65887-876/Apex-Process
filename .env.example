# ─────────────────────────────────────────────────────────────
# Apex Process — Environment variables
# Copy this file to `.env.local` and fill in real values.
# All variables here are SERVER-SIDE ONLY (never prefixed with NEXT_PUBLIC_)
# unless explicitly intended for the browser.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for metadata / Open Graph). Safe to expose.
NEXT_PUBLIC_SITE_URL=https://apexprocess.example.com

# ── Meta Pixel / Conversions API ─────────────────────────────
# Pixel ID — safe to expose (rendered in the browser Pixel snippet).
NEXT_PUBLIC_META_PIXEL_ID=
# Conversions API access token — SERVER ONLY. Never expose to the browser.
META_CAPI_ACCESS_TOKEN=
# Optional: test event code from Events Manager → Test events (leave blank in prod).
META_TEST_EVENT_CODE=

# ── Rate limiting ────────────────────────────────────────────
# Max application submissions allowed per IP within the window.
RATE_LIMIT_MAX=5
# Rate limit window in milliseconds (default 10 minutes).
RATE_LIMIT_WINDOW_MS=600000

# ── Integrations (all optional — see TODO hooks in app/api/apply/route.ts) ──
# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Airtable
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Applications

# Resend (email notifications)
RESEND_API_KEY=
NOTIFY_EMAIL_TO=ops@apexprocess.example.com

# Slack incoming webhook (new-application alerts)
SLACK_WEBHOOK_URL=

# Generic CRM webhook
CRM_WEBHOOK_URL=
